{
  "venvPath": ".",
  "venv": ".venv",
  "pythonVersion": "3.13",
  "pythonPlatform": "Windows",
  "include": [
    "src",
    "tests",
    "scripts",
    "app.py",
    "main.py"
  ],
  "extraPaths": [
    "."
  ],
  "exclude": [
    ".venv",
    "__pycache__",
    "**/__pycache__",
    "**/*.pyc"
  ],
  "typeCheckingMode": "basic",
  "reportMissingModuleSource": "none"
}
